# ── Required ──────────────────────────────────────────────────────────────────
# Get a free API key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Local development: leave as * (all origins allowed)
# Production (Railway): set to your Vercel URL, e.g. https://amanlm.vercel.app
ALLOWED_ORIGINS=*

# ── Chat / RAG model ──────────────────────────────────────────────────────────
# Best text-only models available on Groq (pick one):
#   llama-3.3-70b-versatile      — best quality, recommended
#   llama-3.1-8b-instant         — fastest, lighter
#   mixtral-8x7b-32768           — long context
GROQ_MODEL=llama-3.3-70b-versatile

# ── Audio / video transcription model ─────────────────────────────────────────
# Best speech-to-text models available on Groq (pick one):
#   whisper-large-v3        — highest quality, recommended
#   whisper-large-v3-turbo  — faster, slightly lower quality
GROQ_AUDIO_MODEL=whisper-large-v3

# ── Vision model (images + PDF image extraction) ──────────────────────────────
# Best vision-capable models available on Groq (pick one):
#   meta-llama/llama-4-scout-17b-16e-instruct    — fast, recommended
#   meta-llama/llama-4-maverick-17b-128e-instruct — higher quality, slower
#   llama-3.2-11b-vision-preview                  — older, smaller
#   llama-3.2-90b-vision-preview                  — older, larger
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# ── Chunk compression (optional) ──────────────────────────────────────────────
# When enabled, each parsed chunk is passed through the LLM after ingestion to
# produce a dense, token-efficient representation before it is embedded and
# stored.  This improves retrieval quality and reduces prompt token usage for
# long documents at the cost of longer upload times.
# COMPRESS_MIN_LENGTH: only compress chunks longer than this many characters.
COMPRESS_CHUNKS=false
COMPRESS_MIN_LENGTH=200
