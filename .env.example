# ── Required ──────────────────────────────────────────────────────────────────
# Get a free API key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ── Chat / RAG model ──────────────────────────────────────────────────────────
# Best text-only models available on Groq (pick one):
#   llama-3.3-70b-versatile      — best quality, recommended
#   llama-3.1-8b-instant         — fastest, lighter
#   mixtral-8x7b-32768           — long context
GROQ_MODEL=llama-3.3-70b-versatile

# ── Vision model (images + PDF image extraction) ──────────────────────────────
# Best vision-capable models available on Groq (pick one):
#   meta-llama/llama-4-scout-17b-16e-instruct    — fast, recommended
#   meta-llama/llama-4-maverick-17b-128e-instruct — higher quality, slower
#   llama-3.2-11b-vision-preview                  — older, smaller
#   llama-3.2-90b-vision-preview                  — older, larger
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
